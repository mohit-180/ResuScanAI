{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./*"]
    },

    "esModuleInterop": true,
    "noEmit": false
  }
}